# ─────────────────────────────────────────────────────────────────────────────
# Deep Research Agent — Environment Variables
# Copy this file to .env and fill in your API keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o                   # or gpt-4o-mini for faster/cheaper runs

# ── Tavily Search ─────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000
MCP_LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# ── Research Agent Defaults ───────────────────────────────────────────────────
MAX_SEARCH_RESULTS=5                  # Results per search_web call
MAX_SCRAPE_CHARS=8000                 # Max chars from scrape_content
MAX_HOPS=5                            # Max reasoning hops per query
SUMMARY_MAX_WORDS=150                 # Target summary length
NUM_CLUSTERS=3                        # Clusters for cluster_and_rank

# ── Output ────────────────────────────────────────────────────────────────────
REPORT_FORMAT=markdown_brief          # markdown_brief | comparison_table | insight_report
REPORTS_OUTPUT_DIR=./reports
